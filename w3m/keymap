# Ctrl  : C-, ^
# Alt   : M-
# Escape: ESC-, M-, ^[
# Space : SPC, ' '
# Tab   : TAB, ^i, ^I
# Delete: DEL, ^?
# Up    : UP, ^[[A
# Down  : DOWN, ^[[B
# Right : RIGHT, ^[[C
# Left  : LEFT, ^[[D


# Marks {{{

keymap m MARK
keymap . NEXT_MARK
keymap , PREV_MARK

# Mark all search terms
keymap \" REG_MARK

# Mark URL-like strings as anchors
keymap : MARK_URL

# Mark current word as URL
keymap ";" MARK_WORD

keymap M-: MARK_MID

# }}}


# Navigation {{{

keymap K DOWN
keymap J UP

keymap M-, LEFT
keymap M-. RIGHT

keymap h MOVE_LEFT
keymap j MOVE_DOWN
keymap k MOVE_UP
keymap l MOVE_RIGHT

keymap \^ LINE_BEGIN
keymap $ LINE_END

# }}}


# Links {{{

# Link navigation
keymap TAB NEXT_LINK
keymap M-TAB PREV_LINK
keymap M-j NEXT_LINK
keymap M-k PREV_LINK

keymap [ LINK_BEGIN
keymap ] LINK_END

# Open link in current tab
keymap M-l GOTO_LINK

# Open link in new tab
keymap t TAB_LINK
keymap T TAB_LINK

keymap a SAVE_LINK

# Open link in external browser
keymap o EXTERN_LINK

# Display link URL
keymap u PEEK_LINK

# Link menus
#keymap M-L LIST_MENU
keymap L LIST

# Jump to link
keymap M-m MOVE_LIST_MENU

# }}}


# Pages {{{

keymap SPC NEXT_PAGE
keymap b PREV_PAGE

keymap g BEGIN
keymap G END

keymap ( UNDO
keymap ) REDO

keymap M-g GOTO_LINE
keymap Z CENTER_H
keymap z CENTER_V

# }}}


# Tabs {{{

keymap { PREV_TAB
keymap } NEXT_TAB

# Move tabs around
keymap M-{ TAB_LEFT
keymap M-} TAB_RIGHT

keymap C-q CLOSE_TAB
keymap C-t NEW_TAB
keymap M-t TAB_MENU

# }}}


# Search {{{

# Regular search
keymap / SEARCH
keymap ? SEARCH_BACK
keymap n SEARCH_NEXT
keymap N SEARCH_PREV

# Incremental search
keymap C-r ISEARCH_BACK
keymap C-s ISEARCH

# }}}


# Buffers {{{

# Go to previous buffer closing the current
keymap M-h BACK
keymap B BACK

# Dispaly current buffer URL
keymap c PEEK

# Open current buffer in external browser
keymap O EXTERN

# Open new URL
keymap U GOTO
keymap M-u GOTO_RELATIVE

# Open local file
keymap V LOAD

# Edit source
keymap E EDIT

# Edit buffer (not the source)
keymap M-e EDIT_SCREEN

# Save source
keymap M-s SAVE

keymap | PIPE_BUF

# Save buffer (not the source)
keymap S SAVE_SCREEN

keymap C-l REDRAW

# Reload source URL
keymap R RELOAD

# View source
keymap v VIEW

# Open menu of open buffers
keymap s SELECT_MENU

# }}}


# Images {{{

# View image externally
keymap I VIEW_IMAGE

keymap M-I SAVE_IMAGE

# Peek image URL
keymap i PEEK_IMG

# }}}


# Miscellaneous {{{

# Help
keymap H HELP

# Version
keymap r VERSION

# Options
keymap C-o OPTIONS
keymap M-o SET_OPTION
keymap ! SHELL
keymap # PIPE_SHELL
keymap @ READ_SHELL
keymap C-z SUSPEND

# Quitting
keymap Q EXIT
keymap q QUIT

# Current line information
keymap C-g LINE_INFO

# Page information
keymap = INFO

# History, Cookies and Downloads
keymap C-h HISTORY
keymap C-k COOKIE
keymap D DOWNLOAD_LIST

# Toggle frames
keymap F FRAME

# Toggle mouse
keymap M-m MOUSE_TOGGLE

# Toggle word wrap
keymap C-w WRAP_TOGGLE

# Run commands
keymap M-c COMMAND
#keymap M-k DEFINE_KEY

# Bookmarks
keymap M-a ADD_BOOKMARK

# Dictionary
keymap M-w DICT_WORD
keymap M-W DICT_WORD_AT

# I don't know man
keymap M-[E MENU
keymap M-[L MENU
keymap M-[2~ MENU
keymap M-[28~ MENU
keymap M-b BOOKMARK

# }}}

